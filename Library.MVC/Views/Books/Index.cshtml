@model IEnumerable<Library.Domain.Book>
@{
    ViewData["Title"] = "Books";
}

<h2>📚 Books</h2>

<!-- Search & Filter Form -->
<form method="get" class="row g-2 mb-4">
    <div class="col-md-4">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by title or author..." />
    </div>
    <div class="col-md-3">
        <select name="category" class="form-select">
            <option value="">-- All Categories --</option>
            @foreach (var cat in (List<string>)ViewBag.Categories)
            {
                <option value="@cat" selected="@(ViewBag.Category == cat ? "selected" : null)">@cat</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <select name="availability" class="form-select">
            <option value="">All</option>
            <option value="available" selected="@(ViewBag.Availability == "available" ? "selected" : null)">Available</option>
            <option value="onloan" selected="@(ViewBag.Availability == "onloan" ? "selected" : null)">On Loan</option>
        </select>
    </div>
    <div class="col-md-1">
        <button type="submit" class="btn btn-primary w-100">Filter</button>
    </div>
    <div class="col-md-1">
        <a asp-action="Index" class="btn btn-outline-secondary w-100">Clear</a>
    </div>
</form>

@if (User.Identity?.IsAuthenticated == true)
{
    <a asp-action="Create" class="btn btn-success mb-3">+ Add Book</a>
}

<p class="text-muted">@Model.Count() book(s) found</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Title</th>
            <th>Author</th>
            <th>ISBN</th>
            <th>Category</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td><small class="text-muted">@book.Isbn</small></td>
                <td><span class="badge bg-secondary">@book.Category</span></td>
                <td>
                    @if (book.IsAvailable)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">On Loan</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@book.Id" class="btn btn-sm btn-outline-info">Details</a>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                        <a asp-action="Delete" asp-route-id="@book.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
