@model IEnumerable<Library.Domain.Member>
@{ ViewData["Title"] = "Members"; }
<h2>👥 Members</h2>
@if (User.Identity?.IsAuthenticated == true)
{
    <a asp-action="Create" class="btn btn-success mb-3">+ Add Member</a>
}
<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr><th>Name</th><th>Email</th><th>Phone</th><th></th></tr>
    </thead>
    <tbody>
    @foreach (var m in Model)
    {
        <tr>
            <td>@m.FullName</td>
            <td>@m.Email</td>
            <td>@m.Phone</td>
            <td>
                <a asp-action="Details" asp-route-id="@m.Id" class="btn btn-sm btn-outline-info">Details</a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-action="Edit" asp-route-id="@m.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@m.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                }
            </td>
        </tr>
    }
    </tbody>
</table>
