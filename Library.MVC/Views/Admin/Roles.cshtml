@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>
@{
    ViewData["Title"] = "Role Management";
}

<h2>⚙ Role Management</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row mb-4">
    <div class="col-md-4">
        <form asp-action="CreateRole" method="post">
            @Html.AntiForgeryToken()
            <div class="input-group">
                <input type="text" name="roleName" class="form-control" placeholder="New role name..." required />
                <button type="submit" class="btn btn-success">+ Create Role</button>
            </div>
        </form>
    </div>
</div>

<table class="table table-bordered">
    <thead class="table-dark">
        <tr><th>Role Name</th><th>ID</th><th></th></tr>
    </thead>
    <tbody>
        @foreach (var role in Model)
        {
            <tr>
                <td><strong>@role.Name</strong></td>
                <td><small class="text-muted">@role.Id</small></td>
                <td>
                    @if (role.Name != "Admin")
                    {
                        <form asp-action="DeleteRole" method="post" style="display:inline"
                              onsubmit="return confirm('Delete role @role.Name?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="roleId" value="@role.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                    }
                    else
                    {
                        <span class="text-muted small">Protected</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
